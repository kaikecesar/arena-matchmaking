{
  "name": "arena-matchmaking",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test src/tests/e2e/login.e2e.ts",
    "typecheck": "tsc -b",
    "typecheck:noEmit": "tsc -p tsconfig.app.json --noEmit",
    "validate": "npm run lint && npm run typecheck && npm run build",
    "mcp:install-browsers": "playwright install chromium && npx -y @playwright/mcp@0.0.75 install-browser chromium",
    "validate:comments": "node scripts/fix-section-comments.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "antd": "5.27.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.76.0",
    "react-router-dom": "7.15.1",
    "styled-components": "6.4.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/mcp": "0.0.75",
    "@playwright/test": "1.60.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.12.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "10.3.0",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "playwright": "1.55.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.59.2",
    "vite": "8.0.12",
    "vitest": "4.1.7"
  }
}
